model User {
    id       String   @id @default(uuid())
    name     String
    email    String   @unique
    password String
    role     UserRole

    isDeleted Boolean @default(false)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    gearItems    GearItem[]
    rentalOrders RentalOrder[]
    reviews      Review[]

    @@map("users")
}
